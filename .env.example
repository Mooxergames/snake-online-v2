# Snake Online — marketing site environment.
# Copy to .env.local for local dev. Set the same vars in your host's dashboard
# (Railway / Vercel / Render / Coolify / etc.) for production.

# Backend API base — provides /players for the live leaderboard adapter.
# Skin / arena PNGs are hosted in public/ — backend down ≠ broken site.
BACKEND_API_BASE=https://backend.snakeonline.net

# Legacy alias (older code paths still reference this).
NEXT_PUBLIC_API_BASE=https://backend.snakeonline.net

# Direct asset CDN override. Leave EMPTY to serve from public/ (same-origin).
# Set to a CDN base (e.g. https://cdn.snakeonline.io) when you front the assets
# with a CDN. NEXT_PUBLIC_* is inlined at build time — rebuild after changing it.
NEXT_PUBLIC_ASSETS_BASE=

# Public canonical site URL — used by sitemap, OG, canonical, hreflang, JSON-LD,
# llms.txt, IndexNow. Must be the production origin.
NEXT_PUBLIC_SITE_URL=https://snakeonline.io

# IndexNow protocol key. Must match the .txt filename living in /public/.
# Used by /api/indexnow to authenticate submission and by the .txt file
# that IndexNow fetches to verify ownership.
INDEXNOW_KEY=snakeonlineio2026indexnowkey

# OpenAI key (reserved for the auto-blog system). Leave empty until enabled.
OPENAI_API_KEY=

# Optional — production server port (overridden by most hosts automatically).
# PORT=3001

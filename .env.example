# Backend API base — used by /cdn/* asset rewrite AND server-side ranking fetch.
# REQUIRED at build time for production. Without it, builds fall back to http://localhost:3000.
BACKEND_API_BASE=https://backend.snakeonlines.com

# Optional legacy alias (only used if BACKEND_API_BASE is unset)
NEXT_PUBLIC_API_BASE=https://backend.snakeonlines.com

# Public site URL (used for sitemap, OG, canonical)
NEXT_PUBLIC_SITE_URL=https://snakeonline.io

# IndexNow key (any 8+ alphanumeric value, must match the file in /public)
INDEXNOW_KEY=snakeonlineio2026indexnowkey

# OpenAI key (for the auto-blog system - leave empty until ready)
OPENAI_API_KEY=
